{
	"name": "sybilsedge",
	"compatibility_date": "2026-04-06",
	"compatibility_flags": ["nodejs_compat"],
	"durable_objects": {
		"bindings": [
			{
				"name": "SybilProxyAgent",
				"class_name": "SybilProxyAgent"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["SybilProxyAgent"]
		}
	],
	"assets": {
		"directory": "./dist"
	},
	"observability": {
		"enabled": true
	}
}
