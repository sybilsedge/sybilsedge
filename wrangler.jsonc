{
	"name": "sybilsedge",
	"compatibility_date": "2026-04-06",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"directory": "./dist"
	},
	"observability": {
		"enabled": true
	},
	"env": {
		"preview": {
			"vars": {
				// Preview flag used in code to disable Digital Twin Durable Object access.
				"ENVIRONMENT": "preview"
			}
		}
	}
}
