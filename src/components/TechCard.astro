---
/**
 * TechCard.astro
 * Core card primitive for all content pages (projects, writing, kitchen, posts).
 *
 * Props:
 *   title      — primary heading (Orbitron)
 *   subtitle   — secondary line (slate-300, optional)
 *   tag        — category badge label e.g. "TECH" | "BAKING"
 *   tagColor   — "cyan" | "green" | "amber" (defaults to "cyan")
 *   icon       — inline SVG string rendered via set:html (optional)
 *   href       — makes the card a link (optional)
 *   class      — extra Tailwind classes on the root element (optional)
 */
interface Props {
	title: string;
	subtitle?: string;
	tag?: string;
	tagColor?: 'cyan' | 'green' | 'amber';
	icon?: string;
	href?: string;
	class?: string;
}

const {
	title,
	subtitle,
	tag,
	tagColor = 'cyan',
	icon,
	href,
	class: className = '',
} = Astro.props;

const tagColorMap = {
	cyan:  'text-cyan-300/80',
	green: 'text-[#39ff14]/80',
	amber: 'text-amber-300/80',
};

const tagClass = tagColorMap[tagColor];

const Tag = href ? 'a' : 'article';
---

<Tag
	href={href}
	class={`group blueprint-border rounded-md bg-black/35 p-4 transition-all duration-200
		hover:bg-black/50 hover:shadow-[0_0_16px_rgba(0,255,255,0.08)]
		${href ? 'block no-underline cursor-pointer' : ''}
		${className}`}
>
	<!-- Tag + icon row -->
	{(tag || icon) && (
		<div class="mb-3 flex items-center gap-2">
			{icon && (
				<span class="text-cyan-300 transition-colors group-hover:text-cyan-100" set:html={icon} />
			)}
			{tag && (
				<p class={`font-tech text-[11px] uppercase tracking-[0.16em] ${tagClass}`}>{tag}</p>
			)}
		</div>
	)}

	<!-- Title -->
	<h3 class="font-orbitron text-sm uppercase tracking-[0.08em] text-cyan-100 transition-colors group-hover:text-white">
		{title}
	</h3>

	<!-- Subtitle -->
	{subtitle && (
		<p class="mt-2 text-sm leading-relaxed text-slate-300/90">{subtitle}</p>
	)}

	<!-- Optional footer slot (status badges, dates, links, progress bars) -->
	<slot name="footer" />

	<!-- Default slot (arbitrary extra content) -->
	<slot />
</Tag>
