---
import ActiveProjectStatus from './ActiveProjectStatus';

const entries = [
	{
		iconType: 'pen',
		type: 'WRITING',
		title: 'Noir Garden Journal',
		note: 'Chapter 08 revised with stronger scene transitions.',
		stamp: 'Today 05:40',
	},
	{
		iconType: 'code',
		type: 'CODING',
		title: 'Sybilsedge Dashboard',
		note: 'SSR metrics endpoint hooked into status aggregation.',
		stamp: 'Today 09:15',
	},
	{
		iconType: 'terminal',
		type: 'SYSTEM',
		title: 'CI Pipeline Audit',
		note: 'Dependency locks and test shards scheduled for cleanup.',
		stamp: 'Yesterday 23:12',
	},
];

const icons: Record<string, string> = {
	pen: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>`,
	code: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
	terminal: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
};
---

<section class="blueprint-border rounded-md bg-black/35 p-4 md:p-5">
	<header class="mb-4 flex items-center justify-between">
		<h2 class="font-orbitron text-lg uppercase tracking-[0.16em] text-cyan-100">Status Hub</h2>
		<span class="font-tech text-[11px] uppercase tracking-[0.2em] text-cyan-300/70">Control Plane</span>
	</header>

	<div class="space-y-3">
		<ActiveProjectStatus client:visible />
		{
			entries.map((entry) => (
				<article class="blueprint-border rounded-md bg-black/40 p-3">
					<div class="mb-2 flex items-center gap-2">
						<span class="text-cyan-300" set:html={icons[entry.iconType]} />
						<p class="font-tech text-[11px] uppercase tracking-[0.16em] text-cyan-300/80">{entry.type}</p>
					</div>
					<h3 class="font-orbitron text-sm uppercase tracking-[0.08em] text-cyan-100">{entry.title}</h3>
					<p class="mt-2 text-sm text-slate-300/90">{entry.note}</p>
					<p class="font-tech mt-3 text-[11px] text-cyan-300/70">{entry.stamp}</p>
				</article>
			))
		}
	</div>
</section>
