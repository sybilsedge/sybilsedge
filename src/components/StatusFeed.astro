---
import { TerminalSquare, PenTool, Code2 } from 'lucide-react';
import ActiveProjectStatus from './ActiveProjectStatus';

const entries = [
	{
		icon: PenTool,
		type: 'WRITING',
		title: 'Noir Garden Journal',
		note: 'Chapter 08 revised with stronger scene transitions.',
		stamp: 'Today 05:40',
	},
	{
		icon: Code2,
		type: 'CODING',
		title: 'Sybilsedge Dashboard',
		note: 'SSR metrics endpoint hooked into status aggregation.',
		stamp: 'Today 09:15',
	},
	{
		icon: TerminalSquare,
		type: 'SYSTEM',
		title: 'CI Pipeline Audit',
		note: 'Dependency locks and test shards scheduled for cleanup.',
		stamp: 'Yesterday 23:12',
	},
];
---

<section class="blueprint-border rounded-md bg-black/35 p-4 md:p-5">
	<header class="mb-4 flex items-center justify-between">
		<h2 class="font-orbitron text-lg uppercase tracking-[0.16em] text-cyan-100">Status Feed</h2>
		<span class="font-tech text-[11px] uppercase tracking-[0.2em] text-cyan-300/70">Column 01</span>
	</header>

	<div class="space-y-3">
		<ActiveProjectStatus client:visible />
		{
			entries.map((entry) => (
				<article class="blueprint-border rounded-md bg-black/40 p-3">
					<div class="mb-2 flex items-center gap-2">
						<entry.icon size={16} className="text-cyan-300" />
						<p class="font-tech text-[11px] uppercase tracking-[0.16em] text-cyan-300/80">{entry.type}</p>
					</div>
					<h3 class="font-orbitron text-sm uppercase tracking-[0.08em] text-cyan-100">{entry.title}</h3>
					<p class="mt-2 text-sm text-slate-300/90">{entry.note}</p>
					<p class="font-tech mt-3 text-[11px] text-cyan-300/70">{entry.stamp}</p>
				</article>
			))
		}
	</div>
</section>
