---
import { getCollection } from 'astro:content';
import GalleryIsland from './GalleryIsland.astro';

// Pull 3 most recent recipes
const allRecipes = await getCollection('recipes');
const recipes = allRecipes
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);

// Pull 3 most recent blog posts (exclude drafts)
const allPosts = await getCollection('posts');
const posts = allPosts
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);

// Category icon map
const categoryIcons: Record<string, string> = {
	baking: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 11v3a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1v-3"/><path d="M12 19H4a1 1 0 0 1-1-1v-2a1 1 0 0 1 1-1h16a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1h-3.83"/><path d="m3 11-.88-3.13A2 2 0 0 1 3.86 5.5h16.29a2 2 0 0 1 1.74 2.37L21 11"/><path d="M12 19v3"/></svg>`,
	cooking: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 11h.01"/><path d="M11 15h.01"/><path d="M16 16h.01"/><path d="m2 16 20 6-6-20A20 20 0 0 0 2 16"/><path d="M5.71 17.11a17.04 17.04 0 0 1 11.4-11.4"/></svg>`,
	preservation: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 2h8"/><path d="M9 2v2.789a4 4 0 0 1-.672 2.219l-.656.984A4 4 0 0 0 7 10.212V20a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-9.789a4 4 0 0 0-.672-2.219l-.656-.984A4 4 0 0 1 15 4.788V2"/><path d="M7 15a6.472 6.472 0 0 1 5 0 6.47 6.47 0 0 0 5 0"/></svg>`,
};

const postIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a4 4 0 0 1-4 4z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>`;
---

<section class="blueprint-border rounded-md bg-black/35 p-4 md:p-5">
	<header class="mb-4 flex items-center justify-between">
		<h2 class="font-orbitron text-lg uppercase tracking-[0.16em] text-cyan-100">The Lab</h2>
		<span class="font-tech text-[11px] uppercase tracking-[0.2em] text-cyan-300/70">Experimental Edge</span>
	</header>

	<!-- Culinary Presets -->
	<div class="mb-4">
		<p class="font-tech mb-2 text-[10px] uppercase tracking-[0.22em] text-cyan-300/50">// Culinary Presets</p>
		<div class="space-y-2">
			{recipes.length === 0 ? (
				<div class="blueprint-border rounded-md bg-black/40 p-3 text-center">
					<p class="font-tech text-[11px] text-cyan-300/50">No recipes logged yet</p>
				</div>
			) : (
				recipes.map((recipe) => (
					<a
						href={`/kitchen/${recipe.id}`}
						class="blueprint-border group flex items-start gap-3 rounded-md bg-black/40 p-3 transition-colors hover:bg-cyan-300/5"
					>
						<span class="mt-0.5 shrink-0 text-cyan-300" set:html={categoryIcons[recipe.data.category] ?? categoryIcons.cooking} />
						<div class="min-w-0">
							<p class="font-tech text-[10px] uppercase tracking-[0.18em] text-cyan-300/70">{recipe.data.category}</p>
							<h3 class="font-orbitron truncate text-sm uppercase tracking-[0.08em] text-cyan-100 group-hover:text-cyan-300 transition-colors">{recipe.data.title}</h3>
							{recipe.data.prepTime && (
								<p class="font-tech mt-1 text-[10px] text-cyan-300/50">Prep {recipe.data.prepTime}{recipe.data.cookTime ? ` · Cook ${recipe.data.cookTime}` : ''}</p>
							)}
						</div>
					</a>
				))
			)}
		</div>
	</div>

	<!-- Divider -->
	<div class="my-4 border-t border-cyan-300/10"></div>

	<!-- Tech Posts -->
	<div>
		<p class="font-tech mb-2 text-[10px] uppercase tracking-[0.22em] text-cyan-300/50">// Tech Posts</p>
		<div class="space-y-2">
			{posts.length === 0 ? (
				<div class="blueprint-border rounded-md bg-black/40 p-3">
					<div class="flex items-center gap-2 mb-1">
						<span class="text-cyan-300/40" set:html={postIcon} />
						<p class="font-tech text-[10px] uppercase tracking-[0.18em] text-cyan-300/40">Incoming</p>
					</div>
					<p class="font-orbitron text-sm uppercase tracking-[0.08em] text-cyan-100/40">First transmission pending</p>
					<p class="font-tech mt-1 text-[10px] text-cyan-300/30">Terraform · Networking · AI · Cloud</p>
				</div>
			) : (
				posts.map((post) => (
					<a
						href={`/blog/${post.id}`}
						title="Post detail page coming soon"
						class="blueprint-border group flex items-start gap-3 rounded-md bg-black/40 p-3 transition-colors hover:bg-cyan-300/5"
					>
						<span class="mt-0.5 shrink-0 text-cyan-300" set:html={postIcon} />
						<div class="min-w-0">
							<h3 class="font-orbitron truncate text-sm uppercase tracking-[0.08em] text-cyan-100 group-hover:text-cyan-300 transition-colors">{post.data.title}</h3>
							<p class="mt-1 text-[11px] text-slate-300/70 line-clamp-2">{post.data.description}</p>
							{post.data.tags.length > 0 && (
								<p class="font-tech mt-1 text-[10px] text-cyan-300/50">{post.data.tags.slice(0, 3).join(' · ')}</p>
							)}
						</div>
					</a>
				))
			)}
		</div>
	</div>
</section>
