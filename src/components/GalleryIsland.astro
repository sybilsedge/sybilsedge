---
/**
 * GalleryIsland — Astro wrapper for the GalleryLightbox React island.
 *
 * This component runs entirely on the server:
 *   1. Fetches the requested content collection.
 *   2. Filters entries that have an `image` field.
 *   3. Pre-optimises every image via `getImage()` so the React island only
 *      receives plain, serialisable strings — no Node / Astro APIs needed
 *      inside the client bundle.
 *
 * The React island (`GalleryLightbox`) hydrates with `client:visible` so
 * no JavaScript is shipped until the component scrolls into the viewport.
 *
 * Props:
 *   type        — 'projects' | 'recipes'  (which collection to pull from)
 *   featuredOnly — when true, only items with `featured: true` are included
 *   limit        — cap the number of gallery items (default: all)
 */
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import GalleryLightbox from './GalleryLightbox.tsx';
import type { GalleryItem } from './GalleryLightbox.tsx';
import type { ImageMetadata } from 'astro';

interface Props {
	type: 'projects' | 'recipes';
	featuredOnly?: boolean;
	limit?: number;
}

const { type, featuredOnly = false, limit } = Astro.props;

/** Optimise one image and return a serialisable GalleryItem. */
async function toGalleryItem(
	imageData: { src: ImageMetadata; alt: string },
	title: string,
	caption: string,
): Promise<GalleryItem> {
	const optimised = await getImage({ src: imageData.src, width: 1200, format: 'webp' });
	return {
		src: optimised.src,
		alt: imageData.alt,
		width: optimised.attributes.width ? Number(optimised.attributes.width) : undefined,
		height: optimised.attributes.height ? Number(optimised.attributes.height) : undefined,
		title,
		caption,
	};
}

const rawProjects =
	type === 'projects'
		? (await getCollection('projects'))
				.filter((p) => p.data.image && (!featuredOnly || p.data.featured))
				.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
				.slice(0, limit)
		: [];

const rawRecipes =
	type === 'recipes'
		? (await getCollection('recipes'))
				.filter((r) => r.data.image && (!featuredOnly || r.data.featured))
				.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
				.slice(0, limit)
		: [];

const items: GalleryItem[] = await Promise.all([
	...rawProjects
		.filter((p) => p.data.image)
		.map((p) => toGalleryItem(p.data.image!, p.data.title, p.data.description)),
	...rawRecipes
		.filter((r) => r.data.image)
		.map((r) => toGalleryItem(r.data.image!, r.data.title, r.data.description)),
]);
---

{items.length > 0 && (
	<GalleryLightbox items={items} client:visible />
)}

