---
/**
 * UniverseCard — card for the /writing/ index listing each universe.
 * Active universes link to the hub; planned ones show a "coming soon" treatment.
 */
import type { Universe } from '../../content.config.ts';

interface Props {
	universe: Universe;
}

const { universe } = Astro.props;

const isActive = universe.data.status === 'active';

const globeSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>`;
const arrowSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>`;

const statusClasses: Record<string, string> = {
	active:   'border-[#39ff14]/40 text-[#39ff14]/80 bg-[#39ff14]/5',
	planned:  'border-cyan-300/25 text-cyan-300/50 bg-transparent',
	archived: 'border-slate-500/30 text-slate-500/50 bg-slate-500/5',
};
---

{isActive ? (
	<a
		href={`/writing/${universe.id}/`}
		class="group blueprint-border rounded-md bg-black/35 p-6 flex flex-col gap-4 transition-shadow duration-200 hover:shadow-[0_0_28px_rgba(0,255,255,0.09)] hover:bg-black/50"
	>
		<div class="flex items-start justify-between gap-3">
			<div class="flex items-center gap-2.5">
				<span set:html={globeSvg} class="shrink-0 text-[#39ff14]/70 group-hover:text-[#39ff14] transition-colors" />
				<h2 class="font-orbitron text-base uppercase tracking-[0.1em] text-cyan-100 leading-tight group-hover:text-cyan-300 transition-colors">
					{universe.data.name}
				</h2>
			</div>
			<span class={`shrink-0 rounded border font-tech text-[10px] uppercase tracking-[0.12em] px-2 py-0.5 ${statusClasses[universe.data.status]}`}>
				{universe.data.status}
			</span>
		</div>

		<p class="font-tech text-xs italic text-[#39ff14]/70 leading-snug">
			{universe.data.tagline}
		</p>

		<p class="text-sm leading-relaxed text-slate-300/75 flex-1 line-clamp-3">
			{universe.data.description}
		</p>

		<div class="mt-auto flex items-center gap-1.5 font-tech text-[11px] uppercase tracking-[0.16em] text-cyan-300/50 group-hover:text-[#39ff14]/70 transition-colors">
			Explore Universe
			<span set:html={arrowSvg} />
		</div>
	</a>
) : (
	<div class="blueprint-border rounded-md bg-black/20 p-6 flex flex-col gap-4 opacity-60">
		<div class="flex items-start justify-between gap-3">
			<div class="flex items-center gap-2.5">
				<span set:html={globeSvg} class="shrink-0 text-cyan-300/30" />
				<h2 class="font-orbitron text-base uppercase tracking-[0.1em] text-cyan-100/60 leading-tight">
					{universe.data.name}
				</h2>
			</div>
			<span class={`shrink-0 rounded border font-tech text-[10px] uppercase tracking-[0.12em] px-2 py-0.5 ${statusClasses[universe.data.status]}`}>
				{universe.data.status}
			</span>
		</div>
		<p class="font-tech text-xs italic text-slate-400/60 leading-snug">
			{universe.data.tagline}
		</p>
		<p class="font-tech text-[10px] uppercase tracking-[0.16em] text-cyan-300/30 mt-auto">
			Coming Soon
		</p>
	</div>
)}
