---
/**
 * TimelineEvent — single event node on the universe timeline page.
 * The vertical rail is rendered by the parent page; this component
 * handles the event node content only (pure CSS, no JS).
 */

interface Props {
	title: string;
	summary: string;
	inUniverseDate?: string;
	era?: string;
	slug: string;
	relatedCharacters?: string[];
	relatedStories?: string[];
	relatedLore?: string[];
}

const {
	title,
	summary,
	inUniverseDate,
	era,
	slug,
	relatedCharacters = [],
	relatedStories = [],
	relatedLore = [],
} = Astro.props;
---

<div class="relative pl-8" id={`event-${slug}`}>
	<!-- Node dot on the rail -->
	<div
		class="absolute left-0 top-1.5 h-3 w-3 rounded-full bg-accent/60 border border-accent/30 shadow-[0_0_8px_color-mix(in_srgb,var(--neon-green)_30%,transparent)]"
		aria-hidden="true"
	></div>

	<div class="blueprint-border rounded-md bg-black/35 p-5 flex flex-col gap-3">
		<div class="flex flex-wrap items-start justify-between gap-2">
			<h3 class="font-orbitron text-sm uppercase tracking-[0.1em] text-cyan-100 leading-tight">
				{title}
			</h3>
			{inUniverseDate && (
				<span class="font-tech text-[10px] text-cyan-300/40 shrink-0">{inUniverseDate}</span>
			)}
		</div>

		{era && (
			<span class="font-tech text-[10px] uppercase tracking-[0.16em] text-accent/55">{era}</span>
		)}

		<p class="text-sm leading-relaxed text-slate-300/75">{summary}</p>

		<!-- Cross-collection reference links -->
		{(relatedCharacters.length > 0 || relatedStories.length > 0 || relatedLore.length > 0) && (
			<div class="flex flex-wrap gap-x-4 gap-y-1 font-tech text-[10px] text-cyan-300/40 pt-1 border-t border-cyan-300/10">
				{relatedCharacters.map((slug) => (
					<a href={`/writing/characters/${slug}`} class="hover:text-cyan-300 transition-colors">
						↳ {slug}
					</a>
				))}
				{relatedStories.map((slug) => (
					<a href={`/writing/stories/${slug}`} class="hover:text-cyan-300 transition-colors">
						↳ {slug}
					</a>
				))}
				{relatedLore.map((slug) => (
					<a href={`/writing/lore/${slug}`} class="hover:text-cyan-300 transition-colors">
						↳ {slug}
					</a>
				))}
			</div>
		)}
	</div>
</div>
