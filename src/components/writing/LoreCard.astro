---
/**
 * LoreCard — card for the /writing/lore/ index, grouped by category.
 */
import type { Lore } from '../../content.config.ts';
import CategoryBadge from './CategoryBadge.astro';

interface Props {
	entry: Lore;
}

const { entry } = Astro.props;

const arrowSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>`;
---

<a
	href={`/writing/lore/${entry.id}`}
	class="group blueprint-border rounded-md bg-black/35 p-5 flex flex-col gap-3 transition-shadow duration-200 hover:shadow-[0_0_20px_rgba(0,255,255,0.07)] hover:bg-black/50"
>
	<div class="flex items-center justify-between gap-3">
		<h2 class="font-orbitron text-sm uppercase tracking-[0.1em] text-cyan-100 leading-tight group-hover:text-cyan-300 transition-colors">
			{entry.data.title}
		</h2>
		<CategoryBadge category={entry.data.category} />
	</div>

	<span class="font-tech text-[10px] uppercase tracking-[0.14em] text-cyan-300/40">
		{entry.data.universe}
	</span>

	<div class="mt-auto flex items-center gap-1.5 font-tech text-[11px] uppercase tracking-[0.16em] text-cyan-300/40 group-hover:text-[#39ff14]/70 transition-colors">
		View Entry
		<span set:html={arrowSvg} />
	</div>
</a>
