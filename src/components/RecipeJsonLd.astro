---
/**
 * RecipeJsonLd.astro
 *
 * Injects a schema.org/Recipe JSON-LD <script> into the page <head> via the
 * Layout named "head" slot.  All values come from locally-authored frontmatter
 * so set:html is safe here — there is no user-supplied input involved.
 */

interface Props {
	name: string;
	description: string;
	category: string;
	date: Date;
	prepTime?: string;
	cookTime?: string;
	servings?: number;
	cuisine?: string;
	ingredients?: string[];
	instructions?: string[];
	imageUrl?: string;
}

const {
	name,
	description,
	category,
	date,
	prepTime,
	cookTime,
	servings,
	cuisine,
	ingredients,
	instructions,
	imageUrl,
} = Astro.props;

// Build the JSON-LD object, omitting keys whose values are absent so that
// Google's Rich Results Test does not flag empty/null fields.
const ld: Record<string, unknown> = {
	'@context': 'https://schema.org',
	'@type': 'Recipe',
	name,
	description,
	author: { '@type': 'Person', name: 'Sybil Melton' },
	datePublished: date.toISOString().slice(0, 10),
	recipeCategory: category,
};

if (imageUrl) ld.image = [imageUrl];
// prepTime / cookTime are passed through as authored in frontmatter (e.g. "20 min").
// schema.org prefers ISO 8601 duration strings (e.g. "PT20M"), but Google also
// accepts human-readable values. Update individual recipe entries to ISO 8601 if
// full Rich Results compliance is required.
if (prepTime) ld.prepTime = prepTime;
if (cookTime) ld.cookTime = cookTime;
if (servings) ld.recipeYield = `${servings} servings`;
if (cuisine) ld.recipeCuisine = cuisine;
if (ingredients && ingredients.length > 0) ld.recipeIngredient = ingredients;
if (instructions && instructions.length > 0) {
	ld.recipeInstructions = instructions.map((text) => ({
		'@type': 'HowToStep',
		text,
	}));
}
---

<script type="application/ld+json" set:html={JSON.stringify(ld)} />
