---
import { FileText, BookOpenText, Cpu } from 'lucide-react';

const posts = [
	{
		icon: FileText,
		kind: 'ESSAY',
		title: 'Architecting Quiet Workflows',
		excerpt: 'How to build resilient creator systems without over-automating craft.',
		date: 'Apr 02, 2026',
	},
	{
		icon: Cpu,
		kind: 'TECH',
		title: 'Cloudflare Edge Patterns in Astro',
		excerpt: 'Practical SSR deployment patterns, cache keys, and failure fallbacks.',
		date: 'Mar 28, 2026',
	},
	{
		icon: BookOpenText,
		kind: 'NOTES',
		title: 'Garden Logbook v3',
		excerpt: 'Companion notes on greenhouse airflow and seasonal crop timing.',
		date: 'Mar 18, 2026',
	},
];
---

<section class="blueprint-border rounded-md bg-black/35 p-4 md:p-5">
	<header class="mb-4 flex items-center justify-between">
		<h2 class="font-orbitron text-lg uppercase tracking-[0.16em] text-cyan-100">Other Posts</h2>
		<span class="font-tech text-[11px] uppercase tracking-[0.2em] text-cyan-300/70">Column 03</span>
	</header>

	<div class="space-y-3">
		{
			posts.map((post) => (
				<article class="blueprint-border rounded-md bg-black/40 p-3">
					<div class="mb-2 flex items-center gap-2">
						<post.icon size={16} className="text-cyan-300" />
						<p class="font-tech text-[11px] uppercase tracking-[0.16em] text-cyan-300/80">{post.kind}</p>
					</div>
					<h3 class="font-orbitron text-sm uppercase tracking-[0.08em] text-cyan-100">{post.title}</h3>
					<p class="mt-2 text-sm text-slate-300/90">{post.excerpt}</p>
					<p class="font-tech mt-3 text-[11px] text-cyan-300/70">{post.date}</p>
				</article>
			))
		}
	</div>
</section>
