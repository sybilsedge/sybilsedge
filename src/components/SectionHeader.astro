---
/**
 * SectionHeader.astro
 * Standardised heading block for content sections and full pages.
 *
 * Props:
 *   title      — main heading rendered in Orbitron
 *   subtitle   — supporting description line (optional)
 *   label      — small annotation e.g. "Column 01" or "Writing / Fiction" (optional)
 *   accent     — show Neon Green accent rule below the title (default: false)
 *   align      — "left" | "center" (default: "left")
 */
interface Props {
	title: string;
	subtitle?: string;
	label?: string;
	accent?: boolean;
	align?: 'left' | 'center';
}

const {
	title,
	subtitle,
	label,
	accent = false,
	align = 'left',
} = Astro.props;

const alignClass = align === 'center' ? 'text-center items-center' : 'text-left items-start';
---

<header class={`mb-6 flex flex-col gap-1 ${alignClass}`}>
	<!-- Label annotation -->
	{label && (
		<p class="font-tech text-[11px] uppercase tracking-[0.2em] text-cyan-300/60">{label}</p>
	)}

	<!-- Main title -->
	<h2 class="font-orbitron text-xl uppercase tracking-[0.12em] text-cyan-100 md:text-2xl">
		{title}
	</h2>

	<!-- Neon Green accent rule -->
	{accent && (
		<div class="mt-1 h-px w-12 bg-[#39ff14] shadow-[0_0_8px_rgba(57,255,20,0.6)]" aria-hidden="true" />
	)}

	<!-- Subtitle -->
	{subtitle && (
		<p class="mt-1 max-w-prose text-sm leading-relaxed text-slate-300/80">{subtitle}</p>
	)}
</header>
