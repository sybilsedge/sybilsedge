---
import ThemeToggle from './ThemeToggle.tsx';

const navLinks = [
	{
		href: '/',
		label: 'Dashboard',
		svg: `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/></svg>`,
	},
	{
		href: '/blog',
		label: 'Blog',
		svg: `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a4 4 0 0 1-4 4z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><line x1="10" x2="16" y1="13" y2="13"/><line x1="10" x2="14" y1="17" y2="17"/></svg>`,
	},
	{
		href: '/projects',
		label: 'Projects',
		svg: `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m15 12-8.5 8.5c-.83.83-2.17.83-3 0 0 0 0 0 0 0a2.12 2.12 0 0 1 0-3L12 9"/><path d="M17.64 15 22 10.64"/><path d="m20.91 11.7-1.25-1.25c-.6-.6-.93-1.4-.93-2.25v-.86L16.01 4.6a5.56 5.56 0 0 0-3.94-1.64H9l.92.82A6.18 6.18 0 0 1 12 8.4v1.56l2 2h2.47l2.26 1.91"/></svg>`,
	},
	{
		href: '/kitchen',
		label: 'Kitchen',
		svg: `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>`,
	},
	{
		href: '/about',
		label: 'About',
		svg: `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>`,
	},
	{
		href: '/resume',
		label: 'Resume',
		svg: `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><line x1="10" x2="16" y1="13" y2="13"/><line x1="10" x2="14" y1="17" y2="17"/></svg>`,
	},
	{
		href: '/agent',
		label: 'Twin',
		svg: `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect width="18" height="10" x="3" y="11" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" x2="8" y1="16" y2="16"/><line x1="16" x2="16" y1="16" y2="16"/><line x1="12" x2="12" y1="16" y2="16"/></svg>`,
	},
];

// Writing section: top-level link + sub-sections shown in a dropdown
const writingSubLinks = [
	{ href: '/writing/',            label: 'Universes' },
	{ href: '/writing/novels/',     label: 'Novels' },
	{ href: '/writing/stories/',    label: 'Stories' },
	{ href: '/writing/characters/', label: 'Characters' },
	{ href: '/writing/lore/',       label: 'Lore' },
];

const writingSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>`;
const chevronSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m6 9 6 6 6-6"/></svg>`;

const currentPath = Astro.url.pathname;
const isWritingActive = currentPath.startsWith('/writing');
---

<nav class="blueprint-border-bottom sticky top-0 z-50 bg-[#0a0a0a]/90 backdrop-blur-sm" aria-label="Main navigation">
	<div class="mx-auto flex w-full max-w-[1500px] items-center justify-between px-4 py-3 md:px-8">
		<!-- Wordmark -->
		<a href="/" class="flex items-center gap-2 no-underline" aria-label="Sybilsedge home">
			<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#39ff14" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
			</svg>
			<span class="font-orbitron text-sm font-bold uppercase tracking-[0.2em] text-cyan-100">
				Sybilsedge
			</span>
		</a>

		<!-- Desktop nav links -->
		<ul class="hidden items-center gap-1 md:flex" role="list">
			{
				navLinks.slice(0, 1).map(({ href, label, svg }) => {
					const isActive = currentPath === '/';
					return (
						<li>
							<a
								href={href}
								class={`flex items-center gap-1.5 rounded px-3 py-1.5 font-tech text-[11px] uppercase tracking-[0.16em] transition-colors duration-150 ${
									isActive
										? 'text-[#39ff14] neon-border bg-[#39ff14]/5'
										: 'text-cyan-300/70 hover:text-cyan-100 hover:bg-white/5'
								}`}
								aria-current={isActive ? 'page' : undefined}
							>
								<span set:html={svg} />
								{label}
							</a>
						</li>
					);
				})
			}

			<!-- Writing dropdown -->
			<li class="relative writing-dropdown">
				<a
					href="/writing/"
					class={`flex items-center gap-1.5 rounded px-3 py-1.5 font-tech text-[11px] uppercase tracking-[0.16em] transition-colors duration-150 ${
						isWritingActive
							? 'text-[#39ff14] neon-border bg-[#39ff14]/5'
							: 'text-cyan-300/70 hover:text-cyan-100 hover:bg-white/5'
					}`}
					aria-current={isWritingActive ? 'page' : undefined}
					aria-haspopup="true"
				>
					<span set:html={writingSvg} />
					Writing
					<span set:html={chevronSvg} class="writing-chevron transition-transform duration-150" />
				</a>
				<!-- Sub-menu (shown on hover via CSS) -->
				<ul
					class="writing-submenu absolute left-0 top-full mt-1 w-44 flex-col gap-0.5 rounded-md bg-[#0a0a0a] p-2 blueprint-border hidden"
					role="list"
				>
					{writingSubLinks.map(({ href, label }) => {
						// For the Universes link (/writing/), only mark active on exact match
						// to avoid it highlighting when a sub-section (novels, stories, etc.) is active.
						const isSubActive = href === '/writing/'
							? currentPath === '/writing/'
							: currentPath.startsWith(href);
						return (
							<li>
								<a
									href={href}
									class={`flex items-center rounded px-3 py-1.5 font-tech text-[11px] uppercase tracking-[0.14em] transition-colors ${
										isSubActive
											? 'text-[#39ff14] bg-[#39ff14]/5'
											: 'text-cyan-300/60 hover:text-cyan-100 hover:bg-white/5'
									}`}
									aria-current={isSubActive ? 'page' : undefined}
								>
									{label}
								</a>
							</li>
						);
					})}
				</ul>
			</li>

			{
				navLinks.slice(1).map(({ href, label, svg }) => {
					const isActive = currentPath.startsWith(href);
					return (
						<li>
							<a
								href={href}
								class={`flex items-center gap-1.5 rounded px-3 py-1.5 font-tech text-[11px] uppercase tracking-[0.16em] transition-colors duration-150 ${
									isActive
										? 'text-[#39ff14] neon-border bg-[#39ff14]/5'
										: 'text-cyan-300/70 hover:text-cyan-100 hover:bg-white/5'
								}`}
								aria-current={isActive ? 'page' : undefined}
							>
								<span set:html={svg} />
								{label}
							</a>
						</li>
					);
				})
			}
		</ul>

		<!-- Theme toggle (desktop) -->
		<div class="hidden md:flex">
			<ThemeToggle client:load />
		</div>

		<!-- Mobile hamburger (CSS-only, zero JS) -->
		<div class="relative md:hidden">
			<input type="checkbox" id="mobile-nav-toggle" class="peer sr-only" />
			<label class="nav-toggle cursor-pointer" for="mobile-nav-toggle" aria-label="Toggle navigation menu">
				<div class="flex h-8 w-8 flex-col items-center justify-center gap-1.5">
					<span class="block h-px w-5 bg-cyan-300 transition-all duration-200"></span>
					<span class="block h-px w-5 bg-cyan-300 transition-all duration-200"></span>
					<span class="block h-px w-5 bg-cyan-300 transition-all duration-200"></span>
				</div>
			</label>
			<ul
				class="absolute right-0 top-10 hidden w-52 flex-col gap-1 rounded-md bg-[#0a0a0a] p-2 blueprint-border peer-checked:flex"
				role="list"
			>
				{/* Dashboard */}
				{navLinks.slice(0, 1).map(({ href, label, svg }) => {
					const isActive = currentPath === '/';
					return (
						<li>
							<a
								href={href}
								class={`flex items-center gap-2 rounded px-3 py-2 font-tech text-[11px] uppercase tracking-[0.16em] transition-colors ${
									isActive ? 'text-[#39ff14] bg-[#39ff14]/5' : 'text-cyan-300/70 hover:text-cyan-100 hover:bg-white/5'
								}`}
								aria-current={isActive ? 'page' : undefined}
							>
								<span set:html={svg} />
								{label}
							</a>
						</li>
					);
				})}

				{/* Writing — top link */}
				<li>
					<a
						href="/writing/"
						class={`flex items-center gap-2 rounded px-3 py-2 font-tech text-[11px] uppercase tracking-[0.16em] transition-colors ${
							isWritingActive ? 'text-[#39ff14] bg-[#39ff14]/5' : 'text-cyan-300/70 hover:text-cyan-100 hover:bg-white/5'
						}`}
						aria-current={isWritingActive ? 'page' : undefined}
					>
						<span set:html={writingSvg} />
						Writing
					</a>
				</li>
				{/* Writing sub-links */}
				{writingSubLinks.slice(1).map(({ href, label }) => {
					const isSubActive = currentPath.startsWith(href);
					return (
						<li>
							<a
								href={href}
								class={`flex items-center rounded pl-8 pr-3 py-1.5 font-tech text-[10px] uppercase tracking-[0.14em] transition-colors ${
									isSubActive ? 'text-[#39ff14]/80 bg-[#39ff14]/5' : 'text-cyan-300/50 hover:text-cyan-100 hover:bg-white/5'
								}`}
								aria-current={isSubActive ? 'page' : undefined}
							>
								↳ {label}
							</a>
						</li>
					);
				})}

				{/* Remaining nav links */}
				{navLinks.slice(1).map(({ href, label, svg }) => {
					const isActive = currentPath.startsWith(href);
					return (
						<li>
							<a
								href={href}
								class={`flex items-center gap-2 rounded px-3 py-2 font-tech text-[11px] uppercase tracking-[0.16em] transition-colors ${
									isActive ? 'text-[#39ff14] bg-[#39ff14]/5' : 'text-cyan-300/70 hover:text-cyan-100 hover:bg-white/5'
								}`}
								aria-current={isActive ? 'page' : undefined}
							>
								<span set:html={svg} />
								{label}
							</a>
						</li>
					);
				})}

				{/* Theme toggle */}
				<li class="border-t border-cyan-400/20 pt-1 mt-1">
					<ThemeToggle client:load />
				</li>
			</ul>
		</div>
	</div>
</nav>

<style>
	.blueprint-border-bottom {
		border-bottom: 1px solid rgba(0, 255, 255, 0.25);
		box-shadow: 0 1px 16px rgba(0, 255, 255, 0.06);
	}

	/* Writing dropdown — show on hover (desktop only) */
	.writing-dropdown:hover .writing-submenu,
	.writing-dropdown:focus-within .writing-submenu {
		display: flex;
	}
	.writing-dropdown:hover .writing-chevron,
	.writing-dropdown:focus-within .writing-chevron {
		transform: rotate(180deg);
	}

	/* Hamburger animation: bars morph into × when checkbox is checked */
	#mobile-nav-toggle:checked ~ .nav-toggle div > span:nth-child(1) {
		transform: translateY(0.5rem) rotate(45deg);
	}
	#mobile-nav-toggle:checked ~ .nav-toggle div > span:nth-child(2) {
		opacity: 0;
	}
	#mobile-nav-toggle:checked ~ .nav-toggle div > span:nth-child(3) {
		transform: translateY(-0.625rem) rotate(-45deg);
	}
</style>
