---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allWriting = await getCollection('writing');
const writing = allWriting.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const statuses = ['all', ...new Set(writing.map((w) => w.data.status))] as string[];
---

<Layout
	title="Writing | Sybilsedge"
	description="Near-future science fiction and cyberpunk thrillers. Current project: The Shadow Docket."
	ogImage="/og/writing.png"
>
	<div class="mx-auto w-full max-w-[1200px] px-4 py-6 md:px-8 md:py-10">
		<header class="mb-8 rounded-md blueprint-border bg-black/35 p-6 md:p-8">
			<p class="font-tech text-[11px] uppercase tracking-[0.22em] text-cyan-300/85">Fiction Archive</p>
			<h1 class="font-orbitron mt-2 text-2xl uppercase tracking-[0.12em] text-cyan-100 md:text-3xl">Writing</h1>
			<p class="mt-3 text-base text-slate-300/80">Near-future science fiction and cyberpunk thrillers.</p>
		</header>

		<!-- Filters -->
		<div class="mb-6 flex flex-wrap gap-2">
			{statuses.map((status) => (
				<button
					type="button"
					data-filter={status}
					data-active={status === 'all' ? 'true' : undefined}
					class="rounded blueprint-border px-3 py-1.5 font-tech text-[11px] uppercase tracking-[0.14em] text-cyan-300/60 transition-colors hover:text-cyan-100 data-[active]:text-cyan-100 data-[active]:border-cyan-300/60 data-[active]:bg-cyan-300/5"
				>
					{status === 'all' ? 'All' : status.charAt(0).toUpperCase() + status.slice(1)}
				</button>
			))}
		</div>

		<!-- Grid -->
		<div id="writing-grid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{writing.map((entry) => (
				<article
					data-category={entry.data.status}
					class="blueprint-border rounded-md bg-black/35 p-5 flex flex-col gap-3"
				>
					<div class="flex items-start justify-between gap-2">
						<span class="font-tech text-[10px] uppercase tracking-[0.18em] text-cyan-300/60">{entry.data.genre}</span>
						<span class="font-tech text-[10px] text-cyan-300/35">{entry.data.status.toUpperCase()}</span>
					</div>
					<h2 class="font-orbitron text-sm uppercase tracking-[0.08em] text-cyan-100">{entry.data.title}</h2>
					<p class="text-sm text-slate-300/80 leading-relaxed flex-1">{entry.data.synopsis}</p>
					{entry.data.wordCount && (
						<p class="font-tech text-[10px] text-cyan-300/50">{entry.data.wordCount.toLocaleString()} words</p>
					)}
				</article>
			))}
		</div>
	</div>

	<script>
		const btns = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
		const cards = document.querySelectorAll<HTMLElement>('[data-category]');
		btns.forEach((btn) => {
			btn.addEventListener('click', () => {
				const filter = btn.dataset.filter ?? 'all';
				btns.forEach((b) => b.removeAttribute('data-active'));
				btn.setAttribute('data-active', 'true');
				cards.forEach((card) => {
					card.style.display = (filter === 'all' || card.dataset.category === filter) ? '' : 'none';
				});
			});
		});
	</script>
</Layout>
