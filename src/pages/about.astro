---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="About | Sybilsedge"
	description="Cloud architect, fiction writer, maker. Building things in the physical and digital world."
	ogImage="/og/about.png"
>
	<div class="mx-auto w-full max-w-[1500px] px-4 py-6 md:px-8 md:py-10">
		<header class="mb-8 rounded-md blueprint-border bg-black/35 p-5 md:p-8">
			<p class="font-tech text-[11px] uppercase tracking-[0.22em] text-cyan-300/75">Identity Record</p>
			<h1 class="font-orbitron mt-2 text-2xl uppercase tracking-[0.12em] text-cyan-100 md:text-4xl">About</h1>
		</header>
	</div>
</Layout>
