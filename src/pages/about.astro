---
import Layout from '../layouts/Layout.astro';

const description = 'Cloud architect, fiction writer, maker. 17+ years in IT — a human being with range.';
---

<Layout
	title="About | Sybilsedge"
	description={description}
	ogImage="/og/about.png"
>
	<div class="mx-auto w-full max-w-[960px] px-4 py-6 md:px-8 md:py-10">
		<!-- Page header -->
		<header class="mb-8 rounded-md blueprint-border bg-black/35 p-6 md:p-8">
			<p class="font-tech text-[11px] uppercase tracking-[0.22em] text-cyan-300/85">Identity File</p>
			<h1 class="font-orbitron mt-2 text-2xl uppercase tracking-[0.12em] text-cyan-100 md:text-3xl">About Sybil</h1>
			<p class="mt-4 max-w-2xl text-base leading-relaxed text-slate-300/85">{description}</p>
		</header>
	</div>
</Layout>
