---
/**
 * Paginated blog index — pages 2 and beyond.
 *
 * Page 1 is served by index.astro at /blog/.
 * This file handles /blog/2, /blog/3, etc. via Astro's spread-route + paginate().
 *
 * URL structure:
 *   /blog/       → index.astro  (page 1)
 *   /blog/2      → here         (page 2)
 *   /blog/3      → here         (page 3)
 *
 * Post slugs are never purely numeric so there is no routing collision with
 * /blog/[slug].astro at build time (both use prerender = true).
 */
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import type { GetStaticPathsOptions, Page } from 'astro';
import { getReadingTime } from '../../utils/readingTime.ts';

export const prerender = true;

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
	const PAGE_SIZE = 9;
	const allPosts = await getCollection('posts', ({ data }) => !data.draft);
	const sorted = allPosts.sort(
		(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
	);
	const allPages = paginate(sorted, { pageSize: PAGE_SIZE });
	// Page 1 is served by index.astro; only generate routes for pages 2+.
	return allPages.filter(({ params }) => params.page !== undefined);
}

const { page } = Astro.props as { page: Page<CollectionEntry<'posts'>> };

// For page 2, Astro paginate computes url.prev as '/blog/' (the spread-route
// base). That matches index.astro, so the link is always valid.
const prevUrl = page.url.prev ?? null;
const nextUrl = page.url.next ?? null;

const postIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a4 4 0 0 1-4 4z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><line x1="10" x2="16" y1="13" y2="13"/><line x1="10" x2="14" y1="17" y2="17"/></svg>`;
const arrowSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>`;
const clockSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`;
---

<Layout
	title={`Blog — Page ${page.currentPage} | Sybilsedge`}
	description="Tech posts on cloud architecture, Terraform, networking, AI, and the occasional hard-won lesson from building things."
>
	<div class="mx-auto w-full max-w-[1500px] px-4 py-6 md:px-8 md:py-10">

		<!-- Page header -->
		<header class="mb-8 rounded-md blueprint-border bg-black/35 p-5 md:p-8">
			<p class="font-tech text-[11px] uppercase tracking-[0.22em] text-cyan-300/75">Transmissions</p>
			<h1 class="font-orbitron mt-2 text-2xl uppercase tracking-[0.12em] text-cyan-100 md:text-4xl">
				Blog
			</h1>
			<p class="mt-4 max-w-2xl text-base leading-relaxed text-slate-300/85">
				Cloud architecture, Terraform, networking, AI, and whatever else surfaces after banging on a problem long enough to have something worth writing down.
			</p>
		</header>

		<!-- Post cards -->
		<div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
			{page.data.map((entry) => {
				const formattedDate = entry.data.date.toLocaleDateString('en-US', {
					year: 'numeric',
					month: 'short',
					day: 'numeric',
				});
				const readingTime = getReadingTime(entry.body ?? '');
				return (
					<article class="group blueprint-border rounded-md bg-black/35 p-6 flex flex-col gap-3 transition-shadow duration-200 hover:shadow-[0_0_24px_rgba(0,255,255,0.07)]">

						<!-- Top row: icon + title -->
						<div class="flex items-start gap-2.5">
							<span set:html={postIcon} class="shrink-0 text-accent opacity-70 mt-0.5" />
							<h2 class="font-orbitron text-sm uppercase tracking-[0.1em] text-cyan-100 leading-tight">{entry.data.title}</h2>
						</div>

						<!-- Date + reading time -->
						<div class="flex items-center gap-2 font-tech text-[10px] text-cyan-300/40">
							<span>{formattedDate}</span>
							<span aria-hidden="true">·</span>
							<span class="flex items-center gap-1">
								<span set:html={clockSvg} />
								{readingTime}
							</span>
						</div>

						<!-- Description -->
						<p class="text-sm leading-relaxed text-slate-300/80 flex-1">{entry.data.description}</p>

						<!-- Tags -->
						{entry.data.tags.length > 0 && (
							<div class="flex flex-wrap gap-1.5">
								{entry.data.tags.map((tag: string) => (
									<span class="rounded font-tech text-[10px] uppercase tracking-[0.1em] px-2 py-0.5 bg-black/40 border border-cyan-300/10 text-cyan-300/45">{tag}</span>
								))}
							</div>
						)}

						<!-- Read link -->
						<div class="mt-auto pt-1">
							<a
								href={`/blog/${entry.id}`}
								class="flex items-center gap-1.5 font-tech text-[11px] uppercase tracking-[0.16em] text-accent/60 hover:text-accent transition-colors w-fit"
							>
								Read Post
								<span set:html={arrowSvg} />
							</a>
						</div>
					</article>
				);
			})}
		</div>

		<!-- Pagination -->
		<nav class="mt-10 flex items-center justify-between gap-4" aria-label="Blog pagination">
			<span class="font-tech text-[11px] text-cyan-300/40 uppercase tracking-[0.16em]">
				Page {page.currentPage} of {page.lastPage}
			</span>
			<div class="flex items-center gap-2">
				{prevUrl ? (
					<a
						href={prevUrl}
						class="rounded blueprint-border px-4 py-1.5 font-tech text-[11px] uppercase tracking-[0.16em] text-cyan-300/60 hover:text-cyan-100 transition-colors"
					>
						← Prev
					</a>
				) : (
					<span class="rounded blueprint-border px-4 py-1.5 font-tech text-[11px] uppercase tracking-[0.16em] text-cyan-300/20 cursor-not-allowed" aria-disabled="true">← Prev</span>
				)}
				{nextUrl ? (
					<a
						href={nextUrl}
						class="rounded blueprint-border px-4 py-1.5 font-tech text-[11px] uppercase tracking-[0.16em] text-cyan-300/60 hover:text-cyan-100 transition-colors"
					>
						Next →
					</a>
				) : (
					<span class="rounded blueprint-border px-4 py-1.5 font-tech text-[11px] uppercase tracking-[0.16em] text-cyan-300/20 cursor-not-allowed" aria-disabled="true">Next →</span>
				)}
			</div>
		</nav>

	</div>
</Layout>
