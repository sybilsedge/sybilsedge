---
import Layout from '../layouts/Layout.astro';
import StatusFeed from '../components/StatusFeed.astro';
import BlueprintGallery from '../components/BlueprintGallery.astro';
import TheLab from '../components/TheLab.astro';
---

<Layout
	title="sybilsedge.com | Builder's Console"
	description="Status Hub, Maker Gallery, and The Lab — a live feed of digital builds, physical craft, and experimental output."
	ogImage="/og/home.png"
>
	<main class="mx-auto w-full max-w-[1500px] px-4 py-6 md:px-8 md:py-10">
		<header class="mb-6 rounded-md blueprint-border bg-black/35 p-4 md:mb-8 md:p-6">
			<p class="font-tech text-[11px] uppercase tracking-[0.22em] text-cyan-300/85">Personal Operations Center</p>
			<h1 class="font-orbitron mt-2 text-2xl uppercase tracking-[0.15em] text-cyan-100 md:text-4xl">
				Builder's Console
			</h1>
			<p class="mt-3 max-w-3xl text-sm text-slate-300/90 md:text-base">
				Status Hub, Maker Gallery, and The Lab &mdash; a live feed of digital builds, physical craft, and experimental output.
			</p>
		</header>

		<section class="grid grid-cols-1 gap-4 md:gap-6 xl:grid-cols-3">
			<StatusFeed />
			<BlueprintGallery />
			<TheLab />
		</section>
	</main>
</Layout>
