---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ['all', ...new Set(projects.map((p) => p.data.category))] as string[];
---

<Layout
	title="Projects | Sybilsedge"
	description="Tech builds, home improvement, and garden experiments — documented and in progress."
	ogImage="/og/projects.png"
>
	<div class="mx-auto w-full max-w-[1200px] px-4 py-6 md:px-8 md:py-10">
		<header class="mb-8 rounded-md blueprint-border bg-black/35 p-6 md:p-8">
			<p class="font-tech text-[11px] uppercase tracking-[0.22em] text-cyan-300/85">Maker Archive</p>
			<h1 class="font-orbitron mt-2 text-2xl uppercase tracking-[0.12em] text-cyan-100 md:text-3xl">Projects</h1>
			<p class="mt-3 text-base text-slate-300/80">Tech builds, home improvement, and garden experiments.</p>
		</header>

		<!-- Filters -->
		<div class="mb-6 flex flex-wrap gap-2">
			{categories.map((cat) => (
				<button
					type="button"
					data-filter={cat}
					data-active={cat === 'all' ? 'true' : undefined}
					class="rounded blueprint-border px-3 py-1.5 font-tech text-[11px] uppercase tracking-[0.14em] text-cyan-300/60 transition-colors hover:text-cyan-100 data-[active]:text-cyan-100 data-[active]:border-cyan-300/60 data-[active]:bg-cyan-300/5"
				>
					{cat === 'all' ? 'All' : cat.charAt(0).toUpperCase() + cat.slice(1)}
				</button>
			))}
		</div>

		<!-- Grid -->
		<div id="projects-grid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{projects.map((project) => (
				<article
					data-category={project.data.category}
					class="blueprint-border rounded-md bg-black/35 p-5 flex flex-col gap-3 hover:bg-black/50 transition-colors"
				>
					<div class="flex items-start justify-between gap-2">
						<span class="font-tech text-[10px] uppercase tracking-[0.18em] text-cyan-300/60">{project.data.category}</span>
						<span class="font-tech text-[10px] text-cyan-300/35">{project.data.status.toUpperCase()}</span>
					</div>
					<a href={`/projects/${project.id}`} class="group">
						<h2 class="font-orbitron text-sm uppercase tracking-[0.08em] text-cyan-100 group-hover:text-cyan-300 transition-colors">{project.data.title}</h2>
					</a>
					<p class="text-sm text-slate-300/80 leading-relaxed flex-1">{project.data.description}</p>
					{project.data.tags.length > 0 && (
						<div class="flex flex-wrap gap-1.5">
							{project.data.tags.map((tag: string) => (
								<span class="font-tech text-[10px] uppercase tracking-[0.1em] px-2 py-0.5 rounded bg-black/40 border border-cyan-300/10 text-cyan-300/45">{tag}</span>
							))}
						</div>
					)}
				</article>
			))}
		</div>
	</div>

	<script>
		const btns = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
		const cards = document.querySelectorAll<HTMLElement>('[data-category]');
		btns.forEach((btn) => {
			btn.addEventListener('click', () => {
				const filter = btn.dataset.filter ?? 'all';
				btns.forEach((b) => b.removeAttribute('data-active'));
				btn.setAttribute('data-active', 'true');
				cards.forEach((card) => {
					card.style.display = (filter === 'all' || card.dataset.category === filter) ? '' : 'none';
				});
			});
		});
	</script>
</Layout>
