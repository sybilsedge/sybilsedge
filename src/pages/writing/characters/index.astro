---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import CharacterCard from '../../../components/writing/CharacterCard.astro';

export const prerender = true;

const allCharacters = await getCollection('characters');

// Build list of unique universes for client-side filtering
const universes = [...new Set(allCharacters.map((c) => c.data.universe))].sort();

const personSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#39ff14" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>`;
---

<Layout
	title="Characters | Writing | Sybilsedge"
	description="Character profiles — protagonists, antagonists, and every shadowy figure in between."
	ogImage="/og/writing.png"
>
	<style>
		.char-card-wrapper.is-hidden { display: none; }
	</style>

	<div class="mx-auto w-full max-w-[1200px] px-4 py-6 md:px-8 md:py-10">

		<header class="mb-8 rounded-md blueprint-border bg-black/35 p-5 md:p-8">
			<p class="font-tech text-[11px] uppercase tracking-[0.22em] text-cyan-300/75">Writing / Characters</p>
			<h1 class="font-orbitron mt-2 text-2xl uppercase tracking-[0.12em] text-cyan-100 md:text-4xl">Characters</h1>
			<p class="mt-4 max-w-2xl text-base leading-relaxed text-slate-300/85">
				Protagonists, antagonists, and everyone in between — each page auto-aggregates
				every story, lore entry, and timeline event that references that character.
			</p>
		</header>

		<!-- Universe filter -->
		{universes.length > 1 && (
			<div class="mb-6 flex flex-wrap gap-2" role="group" aria-label="Filter characters by universe">
				<button
					class="filter-btn is-active rounded blueprint-border px-4 py-1.5 font-tech text-[11px] uppercase tracking-[0.16em] transition-colors"
					data-filter="all"
					aria-pressed="true"
				>
					All
				</button>
				{universes.map((u) => (
					<button
						class="filter-btn rounded blueprint-border px-4 py-1.5 font-tech text-[11px] uppercase tracking-[0.16em] transition-colors"
						data-filter={u}
						aria-pressed="false"
					>
						{u}
					</button>
				))}
			</div>
		)}

		{allCharacters.length === 0 ? (
			<div class="blueprint-border rounded-md bg-black/35 p-12 text-center">
				<div class="mb-4 flex justify-center opacity-30" set:html={personSvg} />
				<p class="font-orbitron text-sm uppercase tracking-[0.16em] text-cyan-300/50">No characters yet</p>
				<p class="mt-2 font-tech text-[11px] text-slate-400/60">
					Character entries will appear here once added to the collection.
				</p>
			</div>
		) : (
			<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
				{allCharacters.map((char) => (
					<div class="char-card-wrapper" data-universe={char.data.universe}>
						<CharacterCard character={char} />
					</div>
				))}
			</div>
		)}

	</div>

	<style>
		.filter-btn {
			color: rgba(103, 232, 249, 0.6);
		}
		.filter-btn:hover {
			color: rgba(207, 250, 254, 1);
		}
		.filter-btn.is-active {
			color: rgba(207, 250, 254, 1);
			border-color: rgba(103, 232, 249, 0.6);
			background-color: rgba(103, 232, 249, 0.05);
		}
	</style>

	<script>
		const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
		const wrappers = document.querySelectorAll<HTMLElement>('.char-card-wrapper');

		buttons.forEach((btn) => {
			btn.addEventListener('click', () => {
				const filter = btn.dataset.filter ?? 'all';
				buttons.forEach((b) => {
					const active = b.dataset.filter === filter;
					b.classList.toggle('is-active', active);
					b.setAttribute('aria-pressed', active ? 'true' : 'false');
				});
				wrappers.forEach((w) => {
					w.classList.toggle('is-hidden', filter !== 'all' && w.dataset.universe !== filter);
				});
			});
		});
	</script>
</Layout>
