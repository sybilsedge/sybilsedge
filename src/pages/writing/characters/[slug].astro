---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import CharacterCard from '../../../components/writing/CharacterCard.astro';
import WritingJsonLd from '../../../components/writing/WritingJsonLd.astro';
import { truncateToSentence } from '../../../utils/truncate.ts';

export const prerender = true;

export async function getStaticPaths() {
	const characters = await getCollection('characters');
	return characters.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const slug = entry.id;

// Cross-collection aggregation: find every entry that references this character
const [novels, stories, loreEntries, timelineEvents] = await Promise.all([
	getCollection('novels',       (e) => e.data.relatedCharacters.includes(slug)),
	getCollection('shortStories', (e) => e.data.relatedCharacters.includes(slug)),
	getCollection('lore',         (e) => e.data.relatedCharacters.includes(slug)),
	getCollection('timeline',     (e) => e.data.relatedCharacters.includes(slug)),
]);

// Resolve related character entries for the "Related Characters" section
const relatedCharacters = entry.data.relatedCharacters.length
	? await getCollection('characters', (e) => entry.data.relatedCharacters.includes(e.id))
	: [];

const characterDescription = truncateToSentence(
	entry.data.description ?? `Character profile: ${entry.data.name} — ${entry.data.role}`,
);
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://sybilsedge.com').toString();

---

<Layout
	title={`${entry.data.name} | Characters | Sybilsedge`}
	description={characterDescription}
	ogImage="/og/writing.png"
>
	<WritingJsonLd
		slot="head"
		type="FictionalCharacter"
		title={entry.data.name}
		description={characterDescription}
		canonicalURL={canonicalURL}
		universe={entry.data.universe}
		characterName={entry.data.name}
		role={entry.data.role}
	/>
	<div class="mx-auto w-full max-w-[960px] px-4 py-6 md:px-8 md:py-10">

		<!-- Breadcrumb -->
		<nav class="mb-6 flex items-center gap-1.5 font-tech text-[10px] uppercase tracking-[0.16em] text-cyan-300/40" aria-label="Breadcrumb">
			<a href="/writing/" class="hover:text-cyan-300 transition-colors">Writing</a>
			<span aria-hidden="true">›</span>
			<a href={`/writing/${entry.data.universe}/`} class="hover:text-cyan-300 transition-colors">{entry.data.universe}</a>
			<span aria-hidden="true">›</span>
			<a href="/writing/characters/" class="hover:text-cyan-300 transition-colors">Characters</a>
			<span aria-hidden="true">›</span>
			<span class="text-cyan-300/70">{entry.data.name}</span>
		</nav>

		<!-- Character header -->
		<header class="mb-8 rounded-md blueprint-border bg-black/35 p-6 md:p-8">
			<div class="flex flex-wrap items-start justify-between gap-4">
				<div>
					<p class="font-tech text-[10px] uppercase tracking-[0.2em] text-cyan-300/50 mb-1">{entry.data.universe}</p>
					<h1 class="font-orbitron text-2xl uppercase tracking-[0.1em] text-cyan-100 md:text-3xl">
						{entry.data.name}
					</h1>
					{entry.data.aliases && entry.data.aliases.length > 0 && (
						<p class="mt-1 font-tech text-[11px] text-cyan-300/40 italic">
							aka {entry.data.aliases.join(', ')}
						</p>
					)}
				</div>
				<span class="rounded border border-cyan-300/25 font-tech text-[10px] uppercase tracking-[0.14em] px-2 py-0.5 text-cyan-300/60 bg-cyan-300/5">
					{entry.data.role}
				</span>
			</div>

			{entry.data.affiliation && entry.data.affiliation.length > 0 && (
				<div class="mt-4 flex flex-wrap gap-2">
					{entry.data.affiliation.map((org: string) => (
						<span class="rounded border border-white/10 font-tech text-[10px] px-2 py-0.5 text-slate-400/60">
							{org}
						</span>
					))}
				</div>
			)}

			{entry.data.highlight && (
				<p class="mt-4 font-tech text-sm italic leading-relaxed text-slate-400/70 border-l-2 border-[#39ff14]/25 pl-4">
					{entry.data.highlight}
				</p>
			)}
		</header>

		<!-- Bio / Markdown body -->
		{entry.body && (
			<div class="blueprint-border rounded-md bg-black/35 p-6 md:p-8 prose-writing mb-8">
				<Content />
			</div>
		)}

		<!-- Appears In -->
		{(novels.length > 0 || stories.length > 0) && (
			<aside class="mb-6 blueprint-border rounded-md bg-black/35 p-6">
				<p class="font-tech text-[10px] uppercase tracking-[0.22em] text-cyan-300/50 mb-4">// Appears In</p>
				<ul class="space-y-2" role="list">
					{novels.map((novel) => (
						<li>
							<a
								href={`/writing/novels/${novel.id}`}
								class="group flex items-center justify-between gap-4 rounded blueprint-border bg-black/40 px-4 py-2.5 transition-colors hover:bg-cyan-300/5"
							>
								<span class="font-orbitron text-[11px] uppercase tracking-[0.08em] text-cyan-100 group-hover:text-cyan-300 transition-colors truncate">{novel.data.title}</span>
								<span class="shrink-0 font-tech text-[10px] text-cyan-300/35">Novel</span>
							</a>
						</li>
					))}
					{stories.map((story) => (
						<li>
							<a
								href={`/writing/stories/${story.id}`}
								class="group flex items-center justify-between gap-4 rounded blueprint-border bg-black/40 px-4 py-2.5 transition-colors hover:bg-cyan-300/5"
							>
								<span class="font-orbitron text-[11px] uppercase tracking-[0.08em] text-cyan-100 group-hover:text-cyan-300 transition-colors truncate">{story.data.title}</span>
								<span class="shrink-0 font-tech text-[10px] text-cyan-300/35">Short Story</span>
							</a>
						</li>
					))}
				</ul>
			</aside>
		)}

		<!-- Lore Mentions -->
		{loreEntries.length > 0 && (
			<aside class="mb-6 blueprint-border rounded-md bg-black/35 p-6">
				<p class="font-tech text-[10px] uppercase tracking-[0.22em] text-cyan-300/50 mb-4">// Lore Mentions</p>
				<ul class="space-y-2" role="list">
					{loreEntries.map((loreEntry) => (
						<li>
							<a
								href={`/writing/lore/${loreEntry.id}`}
								class="group flex items-center justify-between gap-4 rounded blueprint-border bg-black/40 px-4 py-2.5 transition-colors hover:bg-cyan-300/5"
							>
								<span class="font-orbitron text-[11px] uppercase tracking-[0.08em] text-cyan-100 group-hover:text-cyan-300 transition-colors truncate">{loreEntry.data.title}</span>
								<span class="shrink-0 font-tech text-[10px] text-cyan-300/35 capitalize">{loreEntry.data.category}</span>
							</a>
						</li>
					))}
				</ul>
			</aside>
		)}

		<!-- Timeline Events -->
		{timelineEvents.length > 0 && (
			<aside class="mb-6 blueprint-border rounded-md bg-black/35 p-6">
				<p class="font-tech text-[10px] uppercase tracking-[0.22em] text-cyan-300/50 mb-4">// Timeline Events</p>
				<ul class="space-y-2" role="list">
					{timelineEvents.map((event) => (
						<li class="rounded blueprint-border bg-black/40 px-4 py-2.5 flex items-center justify-between gap-4">
							<span class="font-orbitron text-[11px] uppercase tracking-[0.08em] text-cyan-100 truncate">{event.data.title}</span>
							{event.data.inUniverseDate && (
								<span class="shrink-0 font-tech text-[10px] text-cyan-300/35">{event.data.inUniverseDate}</span>
							)}
						</li>
					))}
				</ul>
			</aside>
		)}

		<!-- Related Characters -->
		{relatedCharacters.length > 0 && (
			<aside class="mt-8 blueprint-border rounded-md bg-black/35 p-6">
				<p class="font-tech text-[10px] uppercase tracking-[0.22em] text-cyan-300/50 mb-4">// Related Characters</p>
				<div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
					{relatedCharacters.map((char) => (
						<CharacterCard character={char} />
					))}
				</div>
			</aside>
		)}

	</div>

	<style>
		.prose-writing :global(p) {
			font-size: 0.925rem;
			line-height: 1.8;
			color: rgb(148 163 184 / 0.85);
			margin-bottom: 1rem;
		}
		.prose-writing :global(strong) {
			color: rgb(207 250 254 / 0.9);
			font-weight: 600;
		}
		.prose-writing :global(em) {
			color: rgb(57 255 20 / 0.7);
		}
	</style>
</Layout>
