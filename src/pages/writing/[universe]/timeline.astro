---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import TimelineEvent from '../../../components/writing/TimelineEvent.astro';

export const prerender = true;

export async function getStaticPaths() {
	const universes = await getCollection('universes');
	return universes.map((entry) => ({
		params: { universe: entry.id },
		props: { universe: entry },
	}));
}

const { universe } = Astro.props;
const uid = universe.id;

const allEvents = await getCollection('timeline', (e) => e.data.universe === uid);

// Sort: entries with inUniverseDate lexicographically, undefined dates last
const sorted = allEvents.sort((a, b) => {
	if (!a.data.inUniverseDate && !b.data.inUniverseDate) return 0;
	if (!a.data.inUniverseDate) return 1;
	if (!b.data.inUniverseDate) return -1;
	return a.data.inUniverseDate.localeCompare(b.data.inUniverseDate);
});

// Group by era; events without an era go into a null group (rendered last or inline)
const eras: Map<string | null, typeof sorted> = new Map();
for (const event of sorted) {
	const key = event.data.era ?? null;
	if (!eras.has(key)) eras.set(key, []);
	eras.get(key)!.push(event);
}

// Put null-era events first (ungrouped), then named eras
const eraEntries: Array<[string | null, typeof sorted]> = [];
if (eras.has(null)) eraEntries.push([null, eras.get(null)!]);
for (const [era, events] of eras.entries()) {
	if (era !== null) eraEntries.push([era, events]);
}

---

<Layout
	title={`Timeline | ${universe.data.name} | Writing | Sybilsedge`}
	description={`In-universe chronology for ${universe.data.name}`}
	ogImage="/og/writing.png"
>
	<div class="mx-auto w-full max-w-[960px] px-4 py-6 md:px-8 md:py-10">

		<!-- Breadcrumb -->
		<nav class="mb-6 flex items-center gap-1.5 font-tech text-[10px] uppercase tracking-[0.16em] text-cyan-300/40" aria-label="Breadcrumb">
			<a href="/writing/" class="hover:text-cyan-300 transition-colors">Writing</a>
			<span aria-hidden="true">›</span>
			<a href={`/writing/${uid}/`} class="hover:text-cyan-300 transition-colors">{universe.data.name}</a>
			<span aria-hidden="true">›</span>
			<span class="text-cyan-300/70">Timeline</span>
		</nav>

		<header class="mb-8 rounded-md blueprint-border bg-black/35 p-5 md:p-8">
			<p class="font-tech text-[11px] uppercase tracking-[0.22em] text-cyan-300/75">{universe.data.name}</p>
			<h1 class="font-orbitron mt-2 text-2xl uppercase tracking-[0.12em] text-cyan-100 md:text-3xl">Timeline</h1>
			<p class="mt-3 text-base leading-relaxed text-slate-300/80">
				In-universe chronological events{allEvents.length > 0 ? ` — ${allEvents.length} recorded` : ''}.
			</p>
		</header>

		{allEvents.length === 0 ? (
			<div class="blueprint-border rounded-md bg-black/35 p-12 text-center">
				<p class="font-orbitron text-sm uppercase tracking-[0.16em] text-cyan-300/50">No events yet</p>
				<p class="mt-2 font-tech text-[11px] text-slate-400/60">
					Timeline entries will appear here once added to the collection.
				</p>
			</div>
		) : (
			<div class="space-y-10">
				{eraEntries.map(([era, events]) => (
					<section aria-labelledby={era ? `era-${era.replace(/\s+/g, '-').toLowerCase()}` : undefined}>
						{era && (
							<div class="mb-6 flex items-center gap-4">
								<h2
									id={`era-${era.replace(/\s+/g, '-').toLowerCase()}`}
									class="font-orbitron text-sm uppercase tracking-[0.18em] text-[#39ff14]/70"
								>
									{era}
								</h2>
								<div class="flex-1 h-px bg-[#39ff14]/15" aria-hidden="true"></div>
							</div>
						)}

						<!-- Vertical rail + events -->
						<div class="relative">
							<!-- Rail line -->
							<div
								class="absolute left-[5px] top-2 bottom-2 w-px bg-[#39ff14]/20"
								aria-hidden="true"
							></div>

							<div class="space-y-5">
								{events.map((event) => (
									<TimelineEvent
										title={event.data.title}
										summary={event.data.summary}
										inUniverseDate={event.data.inUniverseDate}
										era={event.data.era}
										slug={event.id}
										relatedCharacters={event.data.relatedCharacters}
										relatedStories={event.data.relatedStories}
										relatedLore={event.data.relatedLore}
									/>
								))}
							</div>
						</div>
					</section>
				))}
			</div>
		)}

	</div>
</Layout>
