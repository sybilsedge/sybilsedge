---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import UniverseCard from "../../components/writing/UniverseCard.astro";

export const prerender = true;

const allUniverses = await getCollection("universes");
// Active first, then planned, archived last
const sorted = allUniverses.sort((a, b) => {
	const order = { active: 0, planned: 1, archived: 2 };
	return order[a.data.status] - order[b.data.status];
});

const globeSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#39ff14" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>`;
---

<Layout
	title="Writing | Sybilsedge"
	description="Multi-universe fiction — novels, short stories, lore, and character profiles."
	ogImage="/og/writing.png"
>
	<div class="mx-auto w-full max-w-[1500px] px-4 py-6 md:px-8 md:py-10">
		<header class="mb-8 rounded-md blueprint-border bg-black/35 p-5 md:p-8">
			<p
				class="font-tech text-[11px] uppercase tracking-[0.22em] text-cyan-300/75"
			>
				Fiction Portfolio
			</p>
			<h1
				class="font-orbitron mt-2 text-2xl uppercase tracking-[0.12em] text-cyan-100 md:text-4xl"
			>
				Writing
			</h1>
			<p
				class="mt-4 max-w-2xl text-base leading-relaxed text-slate-300/85"
			>
				Novels, short stories, lore, and character profiles — organized
				by universe. Sci-fi thrillers, corporate dystopia, and anything
				else that escapes the terminal at night.
			</p>
			<!-- Sub-section links -->
			<div
				class="mt-5 flex flex-wrap gap-2"
				role="list"
				aria-label="Writing sections"
			>
				{
					[
						{ href: "/writing/novels/", label: "Novels" },
						{ href: "/writing/stories/", label: "Stories" },
						{ href: "/writing/characters/", label: "Characters" },
						{ href: "/writing/lore/", label: "Lore" },
					].map(({ href, label }) => (
						<a
							href={href}
							class="rounded blueprint-border px-4 py-1.5 font-tech text-[11px] uppercase tracking-[0.16em] text-cyan-300/60 hover:text-cyan-100 hover:bg-white/5 transition-colors"
						>
							{label}
						</a>
					))
				}
			</div>
		</header>

		{
			sorted.length === 0 ? (
				<div class="blueprint-border rounded-md bg-black/35 p-12 text-center">
					<div
						class="mb-4 flex justify-center opacity-30"
						set:html={globeSvg}
					/>
					<p class="font-orbitron text-sm uppercase tracking-[0.16em] text-cyan-300/50">
						No universes yet
					</p>
					<p class="mt-2 font-tech text-[11px] text-slate-400/60">
						Universe entries will appear here once added to the
						collection.
					</p>
				</div>
			) : (
				<div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
					{sorted.map((universe) => (
						<UniverseCard universe={universe} />
					))}
				</div>
			)
		}
	</div>
</Layout>
