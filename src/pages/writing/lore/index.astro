---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import LoreCard from '../../../components/writing/LoreCard.astro';
import CategoryBadge from '../../../components/writing/CategoryBadge.astro';

export const prerender = true;

const allLore = await getCollection('lore');

// Sort alphabetically within each category
const sorted = allLore.sort((a, b) => a.data.title.localeCompare(b.data.title));

const universes = [...new Set(allLore.map((e) => e.data.universe))].sort();

// Group by category for the grouped display
const CATEGORIES = ['location', 'faction', 'technology', 'history', 'culture', 'other'] as const;
type LoreCategory = typeof CATEGORIES[number];

const grouped = CATEGORIES.reduce<Record<LoreCategory, typeof sorted>>((acc, cat) => {
	acc[cat] = sorted.filter((e) => e.data.category === cat);
	return acc;
}, {} as Record<LoreCategory, typeof sorted>);

const bookOpenSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`;
---

<Layout
	title="Lore | Writing | Sybilsedge"
	description="World-building entries — locations, factions, technology, history, and culture."
	ogImage="/og/writing.png"
>
	<style>
		.lore-card-wrapper.is-hidden { display: none; }
		.filter-btn { color: rgba(103, 232, 249, 0.6); }
		.filter-btn:hover { color: rgba(207, 250, 254, 1); }
		.filter-btn.is-active {
			color: rgba(207, 250, 254, 1);
			border-color: rgba(103, 232, 249, 0.6);
			background-color: rgba(103, 232, 249, 0.05);
		}
	</style>

	<div class="mx-auto w-full max-w-[1200px] px-4 py-6 md:px-8 md:py-10">

		<header class="mb-8 rounded-md blueprint-border bg-black/35 p-5 md:p-8">
			<p class="font-tech text-[11px] uppercase tracking-[0.22em] text-cyan-300/75">Writing / Lore</p>
			<h1 class="font-orbitron mt-2 text-2xl uppercase tracking-[0.12em] text-cyan-100 md:text-4xl">Lore</h1>
			<p class="mt-4 max-w-2xl text-base leading-relaxed text-slate-300/85">
				World-building entries — locations, factions, technology, history, and culture.
			</p>
		</header>

		<!-- Universe filter -->
		{universes.length > 1 && (
			<div class="mb-6 flex flex-wrap gap-2" role="group" aria-label="Filter lore by universe">
				<button class="filter-btn is-active rounded blueprint-border px-4 py-1.5 font-tech text-[11px] uppercase tracking-[0.16em] transition-colors" data-filter="all" aria-pressed="true">All</button>
				{universes.map((u) => (
					<button class="filter-btn rounded blueprint-border px-4 py-1.5 font-tech text-[11px] uppercase tracking-[0.16em] transition-colors" data-filter={u} aria-pressed="false">{u}</button>
				))}
			</div>
		)}

		{allLore.length === 0 ? (
			<div class="blueprint-border rounded-md bg-black/35 p-12 text-center">
				<div class="mb-4 flex justify-center opacity-30 text-accent" set:html={bookOpenSvg} />
				<p class="font-orbitron text-sm uppercase tracking-[0.16em] text-cyan-300/50">No lore entries yet</p>
				<p class="mt-2 font-tech text-[11px] text-slate-400/60">Lore entries will appear here once added to the collection.</p>
			</div>
		) : (
			<div class="space-y-10">
				{CATEGORIES.map((cat) => {
					const entries = grouped[cat];
					if (entries.length === 0) return null;
					return (
						<section aria-labelledby={`cat-${cat}`}>
							<div class="mb-4 flex items-center gap-3">
								<h2 id={`cat-${cat}`} class="font-orbitron text-sm uppercase tracking-[0.16em] text-cyan-300/70">
									// {cat}
								</h2>
								<CategoryBadge category={cat} />
							</div>
							<div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
								{entries.map((entry) => (
									<div class="lore-card-wrapper" data-universe={entry.data.universe}>
										<LoreCard entry={entry} />
									</div>
								))}
							</div>
						</section>
					);
				})}
			</div>
		)}

	</div>

	<script>
		const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
		const wrappers = document.querySelectorAll<HTMLElement>('.lore-card-wrapper');
		buttons.forEach((btn) => {
			btn.addEventListener('click', () => {
				const filter = btn.dataset.filter ?? 'all';
				buttons.forEach((b) => {
					const active = b.dataset.filter === filter;
					b.classList.toggle('is-active', active);
					b.setAttribute('aria-pressed', active ? 'true' : 'false');
				});
				wrappers.forEach((w) => {
					w.classList.toggle('is-hidden', filter !== 'all' && w.dataset.universe !== filter);
				});
			});
		});
	</script>
</Layout>
