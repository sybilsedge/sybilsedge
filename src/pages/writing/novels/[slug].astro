---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import ContentHero from '../../../components/ContentHero.astro';
import StatusBadge from '../../../components/writing/StatusBadge.astro';
import CharacterCard from '../../../components/writing/CharacterCard.astro';
import WritingJsonLd from '../../../components/writing/WritingJsonLd.astro';
import { truncateToSentence } from '../../../utils/truncate.ts';
import { getReadingTime } from '../../../utils/readingTime.ts';

export const prerender = true;

export async function getStaticPaths() {
	const novels = await getCollection('novels');
	return novels.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Resolve related character entries
const relatedCharacters = entry.data.relatedCharacters.length
	? await getCollection('characters', (e) => entry.data.relatedCharacters.includes(e.id))
	: [];

const novelDescription = truncateToSentence(entry.data.synopsis);
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://sybilsedge.com').toString();

const readingTime = entry.body?.trim().length ? getReadingTime(entry.body) : null;

const clockSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`;

---

<Layout
	title={`${entry.data.title} | Novels | Sybilsedge`}
	description={novelDescription}
	ogImage="/og/writing.png"
>
	<WritingJsonLd
		slot="head"
		type="Book"
		title={entry.data.title}
		description={novelDescription}
		canonicalURL={canonicalURL}
		universe={entry.data.universe}
	/>
	<div class="mx-auto w-full max-w-[960px] px-4 py-6 md:px-8 md:py-10">

		<!-- Breadcrumb -->
		<nav class="mb-6 flex items-center gap-1.5 font-tech text-[10px] uppercase tracking-[0.16em] text-cyan-300/40" aria-label="Breadcrumb">
			<a href="/writing/" class="hover:text-cyan-300 transition-colors">Writing</a>
			<span aria-hidden="true">›</span>
			<a href={`/writing/${entry.data.universe}/`} class="hover:text-cyan-300 transition-colors">{entry.data.universe}</a>
			<span aria-hidden="true">›</span>
			<a href="/writing/novels/" class="hover:text-cyan-300 transition-colors">Novels</a>
			<span aria-hidden="true">›</span>
			<span class="text-cyan-300/70 truncate">{entry.data.title}</span>
		</nav>

		<!-- Header -->
		<header class="mb-8 rounded-md blueprint-border bg-black/35 p-6 md:p-8">
			<div class="mb-3 flex flex-wrap items-center gap-2">
				<span class="font-tech text-[10px] uppercase tracking-[0.18em] text-cyan-300/55">{entry.data.universe}</span>
				<span class="text-cyan-300/20" aria-hidden="true">·</span>
				<StatusBadge status={entry.data.status} />
				{entry.data.readingOrder !== undefined && (
					<>
						<span class="text-cyan-300/20" aria-hidden="true">·</span>
						<span class="font-tech text-[10px] text-cyan-300/35">#{entry.data.readingOrder}</span>
					</>
				)}
				{readingTime && (
					<>
						<span class="text-cyan-300/20" aria-hidden="true">·</span>
						<span class="flex items-center gap-1 font-tech text-[10px] text-cyan-300/35">
							<span set:html={clockSvg} />
							{readingTime}
						</span>
					</>
				)}
			</div>

			<h1 class="font-orbitron text-2xl uppercase tracking-[0.1em] text-cyan-100 md:text-3xl">
				{entry.data.title}
			</h1>

			{entry.data.coverImage && (
				<ContentHero
					src={entry.data.coverImage.src}
					alt={entry.data.coverImage.alt}
					class="mt-6"
				/>
			)}
		</header>

		<!-- Synopsis -->
		<section class="mb-8 blueprint-border rounded-md bg-black/35 p-6 md:p-8">
			<p class="font-tech text-[10px] uppercase tracking-[0.22em] text-cyan-300/50 mb-4">// Synopsis</p>
			<p class="text-base leading-relaxed text-slate-300/85 whitespace-pre-line">{entry.data.synopsis}</p>
		</section>

		<!-- Excerpt (rendered MDX body) -->
		{entry.body && (
			<section class="mb-8 blueprint-border rounded-md bg-black/35 p-6 md:p-8">
				<p class="font-tech text-[10px] uppercase tracking-[0.22em] text-cyan-300/50 mb-6">// Excerpt</p>
				<div class="prose-novel border-l-2 border-[#39ff14]/20 pl-6">
					<Content />
				</div>
			</section>
		)}

		<!-- Related Characters -->
		{relatedCharacters.length > 0 && (
			<aside class="mt-8 blueprint-border rounded-md bg-black/35 p-6">
				<p class="font-tech text-[10px] uppercase tracking-[0.22em] text-cyan-300/50 mb-4">// Characters</p>
				<div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
					{relatedCharacters.map((char) => (
						<CharacterCard character={char} />
					))}
				</div>
			</aside>
		)}

	</div>

	<style>
		.prose-novel :global(p) {
			font-size: 0.975rem;
			line-height: 1.9;
			color: rgb(148 163 184 / 0.9);
			margin-bottom: 1.25rem;
			max-width: 68ch;
		}
		.prose-novel :global(strong) {
			color: rgb(207 250 254 / 0.9);
			font-weight: 600;
		}
		.prose-novel :global(em) {
			color: rgb(57 255 20 / 0.7);
			font-style: italic;
		}
	</style>
</Layout>
