---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import NovelCard from '../../../components/writing/NovelCard.astro';

export const prerender = true;

const allNovels = await getCollection('novels');

// Sort by readingOrder (undefined entries last), then title
const sorted = allNovels.sort((a, b) => {
	if (a.data.readingOrder === undefined && b.data.readingOrder === undefined) {
		return a.data.title.localeCompare(b.data.title);
	}
	if (a.data.readingOrder === undefined) return 1;
	if (b.data.readingOrder === undefined) return -1;
	if (a.data.readingOrder !== b.data.readingOrder) return a.data.readingOrder - b.data.readingOrder;
	return a.data.title.localeCompare(b.data.title);
});

const universes = [...new Set(allNovels.map((n) => n.data.universe))].sort();

const bookSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>`;
---

<Layout
	title="Novels | Writing | Sybilsedge"
	description="Novels and long-form fiction — sorted by reading order."
	ogImage="/og/writing.png"
>
	<style>
		.novel-card-wrapper.is-hidden { display: none; }
		.filter-btn { color: rgba(103, 232, 249, 0.6); }
		.filter-btn:hover { color: rgba(207, 250, 254, 1); }
		.filter-btn.is-active {
			color: rgba(207, 250, 254, 1);
			border-color: rgba(103, 232, 249, 0.6);
			background-color: rgba(103, 232, 249, 0.05);
		}
	</style>

	<div class="mx-auto w-full max-w-[1200px] px-4 py-6 md:px-8 md:py-10">

		<header class="mb-8 rounded-md blueprint-border bg-black/35 p-5 md:p-8">
			<p class="font-tech text-[11px] uppercase tracking-[0.22em] text-cyan-300/75">Writing / Novels</p>
			<h1 class="font-orbitron mt-2 text-2xl uppercase tracking-[0.12em] text-cyan-100 md:text-4xl">Novels</h1>
			<p class="mt-4 max-w-2xl text-base leading-relaxed text-slate-300/85">
				Long-form fiction, sorted by in-universe reading order.
			</p>
		</header>

		{universes.length > 1 && (
			<div class="mb-6 flex flex-wrap gap-2" role="group" aria-label="Filter novels by universe">
				<button class="filter-btn is-active rounded blueprint-border px-4 py-1.5 font-tech text-[11px] uppercase tracking-[0.16em] transition-colors" data-filter="all" aria-pressed="true">All</button>
				{universes.map((u) => (
					<button class="filter-btn rounded blueprint-border px-4 py-1.5 font-tech text-[11px] uppercase tracking-[0.16em] transition-colors" data-filter={u} aria-pressed="false">{u}</button>
				))}
			</div>
		)}

		{sorted.length === 0 ? (
			<div class="blueprint-border rounded-md bg-black/35 p-12 text-center">
				<div class="mb-4 flex justify-center opacity-30 text-accent" set:html={bookSvg} />
				<p class="font-orbitron text-sm uppercase tracking-[0.16em] text-cyan-300/50">No novels yet</p>
				<p class="mt-2 font-tech text-[11px] text-slate-400/60">Novel entries will appear here once added to the collection.</p>
			</div>
		) : (
			<div class="grid grid-cols-1 gap-5 md:grid-cols-2">
				{sorted.map((novel) => (
					<div class="novel-card-wrapper" data-universe={novel.data.universe}>
						<NovelCard novel={novel} />
					</div>
				))}
			</div>
		)}

	</div>

	<script>
		const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
		const wrappers = document.querySelectorAll<HTMLElement>('.novel-card-wrapper');
		buttons.forEach((btn) => {
			btn.addEventListener('click', () => {
				const filter = btn.dataset.filter ?? 'all';
				buttons.forEach((b) => {
					const active = b.dataset.filter === filter;
					b.classList.toggle('is-active', active);
					b.setAttribute('aria-pressed', active ? 'true' : 'false');
				});
				wrappers.forEach((w) => {
					w.classList.toggle('is-hidden', filter !== 'all' && w.dataset.universe !== filter);
				});
			});
		});
	</script>
</Layout>
