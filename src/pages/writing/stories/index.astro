---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import StoryCard from '../../../components/writing/StoryCard.astro';

export const prerender = true;

const allStories = await getCollection('shortStories');

const sorted = allStories.sort((a, b) => {
	if (a.data.readingOrder === undefined && b.data.readingOrder === undefined) {
		return a.data.title.localeCompare(b.data.title);
	}
	if (a.data.readingOrder === undefined) return 1;
	if (b.data.readingOrder === undefined) return -1;
	return a.data.readingOrder - b.data.readingOrder;
});

const universes = [...new Set(allStories.map((s) => s.data.universe))].sort();
const allTags   = [...new Set(allStories.flatMap((s) => s.data.tags))].sort();

const penSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>`;
---

<Layout
	title="Short Stories | Writing | Sybilsedge"
	description="Short fiction — sorted by in-universe reading order."
	ogImage="/og/writing.png"
>
	<style>
		.story-card-wrapper.is-hidden { display: none; }
		.filter-btn { color: rgba(103, 232, 249, 0.6); }
		.filter-btn:hover { color: rgba(207, 250, 254, 1); }
		.filter-btn.is-active {
			color: rgba(207, 250, 254, 1);
			border-color: rgba(103, 232, 249, 0.6);
			background-color: rgba(103, 232, 249, 0.05);
		}
	</style>

	<div class="mx-auto w-full max-w-[1200px] px-4 py-6 md:px-8 md:py-10">

		<header class="mb-8 rounded-md blueprint-border bg-black/35 p-5 md:p-8">
			<p class="font-tech text-[11px] uppercase tracking-[0.22em] text-cyan-300/75">Writing / Stories</p>
			<h1 class="font-orbitron mt-2 text-2xl uppercase tracking-[0.12em] text-cyan-100 md:text-4xl">Short Stories</h1>
			<p class="mt-4 max-w-2xl text-base leading-relaxed text-slate-300/85">
				Short fiction, sorted by in-universe reading order.
			</p>
		</header>

		<!-- Universe filter -->
		{universes.length > 1 && (
			<div class="mb-4 flex flex-wrap gap-2" role="group" aria-label="Filter stories by universe">
				<button class="filter-btn is-active rounded blueprint-border px-4 py-1.5 font-tech text-[11px] uppercase tracking-[0.16em] transition-colors" data-filter-universe="all" aria-pressed="true">All Universes</button>
				{universes.map((u) => (
					<button class="filter-btn rounded blueprint-border px-4 py-1.5 font-tech text-[11px] uppercase tracking-[0.16em] transition-colors" data-filter-universe={u} aria-pressed="false">{u}</button>
				))}
			</div>
		)}

		<!-- Tag filter -->
		{allTags.length > 0 && (
			<div class="mb-6 flex flex-wrap gap-2" role="group" aria-label="Filter stories by tag">
				<button class="filter-btn is-active rounded blueprint-border px-3 py-1 font-tech text-[10px] uppercase tracking-[0.14em] transition-colors" data-filter-tag="all" aria-pressed="true">All Tags</button>
				{allTags.map((tag) => (
					<button class="filter-btn rounded blueprint-border px-3 py-1 font-tech text-[10px] uppercase tracking-[0.14em] transition-colors" data-filter-tag={tag} aria-pressed="false">{tag}</button>
				))}
			</div>
		)}

		{sorted.length === 0 ? (
			<div class="blueprint-border rounded-md bg-black/35 p-12 text-center">
				<div class="mb-4 flex justify-center opacity-30 text-accent" set:html={penSvg} />
				<p class="font-orbitron text-sm uppercase tracking-[0.16em] text-cyan-300/50">No stories yet</p>
				<p class="mt-2 font-tech text-[11px] text-slate-400/60">Short story entries will appear here once added to the collection.</p>
			</div>
		) : (
			<div class="grid grid-cols-1 gap-4 md:grid-cols-2">
				{sorted.map((story) => (
					<div
						class="story-card-wrapper"
						data-universe={story.data.universe}
						data-tags={story.data.tags.join(',')}
					>
						<StoryCard story={story} />
					</div>
				))}
			</div>
		)}

	</div>

	<script>
		let activeUniverse = 'all';
		let activeTag = 'all';

		function applyFilters() {
			document.querySelectorAll<HTMLElement>('.story-card-wrapper').forEach((w) => {
				const universeMatch = activeUniverse === 'all' || w.dataset.universe === activeUniverse;
				const tags = (w.dataset.tags ?? '').split(',').filter(Boolean);
				const tagMatch = activeTag === 'all' || tags.includes(activeTag);
				w.classList.toggle('is-hidden', !universeMatch || !tagMatch);
			});
		}

		document.querySelectorAll<HTMLButtonElement>('[data-filter-universe]').forEach((btn) => {
			btn.addEventListener('click', () => {
				activeUniverse = btn.dataset.filterUniverse ?? 'all';
				document.querySelectorAll<HTMLButtonElement>('[data-filter-universe]').forEach((b) => {
					const active = b.dataset.filterUniverse === activeUniverse;
					b.classList.toggle('is-active', active);
					b.setAttribute('aria-pressed', active ? 'true' : 'false');
				});
				applyFilters();
			});
		});

		document.querySelectorAll<HTMLButtonElement>('[data-filter-tag]').forEach((btn) => {
			btn.addEventListener('click', () => {
				activeTag = btn.dataset.filterTag ?? 'all';
				document.querySelectorAll<HTMLButtonElement>('[data-filter-tag]').forEach((b) => {
					const active = b.dataset.filterTag === activeTag;
					b.classList.toggle('is-active', active);
					b.setAttribute('aria-pressed', active ? 'true' : 'false');
				});
				applyFilters();
			});
		});
	</script>
</Layout>
